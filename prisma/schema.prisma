generator client {
  provider     = "prisma-client"
  output       = "../src/common/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model BinhLuan {
  id                 Int        @id @default(autoincrement())
  ma_cong_viec       Int?
  ma_nguoi_binh_luan Int?
  ngay_binh_luan     DateTime?  @db.DateTime(0)
  noi_dung           String?    @db.VarChar(500)
  sao_binh_luan      Int?
  deletedBy          Int        @default(0)
  isDeleted          Boolean    @default(false)
  deletedAt          DateTime?  @db.Timestamp(0)
  createdAt          DateTime   @default(now()) @db.Timestamp(0)
  updatedAt          DateTime   @default(now()) @db.Timestamp(0)
  CongViec           CongViec?  @relation(fields: [ma_cong_viec], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_BinhLuan_CongViec")
  NguoiDung          NguoiDung? @relation(fields: [ma_nguoi_binh_luan], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_BinhLuan_NguoiDung")

  @@index([ma_cong_viec], map: "FK_BinhLuan_CongViec")
  @@index([ma_nguoi_binh_luan], map: "FK_BinhLuan_NguoiDung")
}

model ChiTietLoaiCongViec {
  id                Int           @id @default(autoincrement())
  ten_chi_tiet      String?       @db.VarChar(255)
  hinh_anh          String?       @db.VarChar(255)
  ma_loai_cong_viec Int?
  deletedBy         Int           @default(0)
  isDeleted         Boolean       @default(false)
  deletedAt         DateTime?     @db.Timestamp(0)
  createdAt         DateTime      @default(now()) @db.Timestamp(0)
  updatedAt         DateTime      @default(now()) @db.Timestamp(0)
  LoaiCongViec      LoaiCongViec? @relation(fields: [ma_loai_cong_viec], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_ChiTiet_Loai")
  CongViec          CongViec[]

  @@index([ma_loai_cong_viec], map: "FK_ChiTiet_Loai")
}

model CongViec {
  id                  Int                  @id @default(autoincrement())
  ten_cong_viec       String?              @db.VarChar(255)
  danh_gia            Int?
  gia_tien            Int?
  hinh_anh            String?              @db.VarChar(255)
  mo_ta               String?              @db.VarChar(1000)
  mo_ta_ngan          String?              @db.VarChar(255)
  sao_cong_viec       Int?
  ma_chi_tiet_loai    Int?
  nguoi_tao           Int?
  deletedBy           Int                  @default(0)
  isDeleted           Boolean              @default(false)
  deletedAt           DateTime?            @db.Timestamp(0)
  createdAt           DateTime             @default(now()) @db.Timestamp(0)
  updatedAt           DateTime             @default(now()) @db.Timestamp(0)
  BinhLuan            BinhLuan[]
  ChiTietLoaiCongViec ChiTietLoaiCongViec? @relation(fields: [ma_chi_tiet_loai], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_CongViec_ChiTiet")
  NguoiDung           NguoiDung?           @relation(fields: [nguoi_tao], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_CongViec_NguoiTao")
  ThueCongViec        ThueCongViec[]

  @@index([ma_chi_tiet_loai], map: "FK_CongViec_ChiTiet")
  @@index([nguoi_tao], map: "FK_CongViec_NguoiTao")
}

model LoaiCongViec {
  id                  Int                   @id @default(autoincrement())
  ten_loai_cong_viec  String?               @db.VarChar(255)
  ChiTietLoaiCongViec ChiTietLoaiCongViec[]
}

model NguoiDung {
  id            Int            @id @default(autoincrement())
  name          String?        @db.VarChar(255)
  email         String?        @db.VarChar(255)
  pass_word     String?        @db.VarChar(255)
  phone         String?        @db.VarChar(20)
  birth_day     String?        @db.VarChar(50)
  gender        String?        @db.VarChar(20)
  role          String?        @db.VarChar(50)
  skill         String?        @db.VarChar(255)
  certification String?        @db.VarChar(255)
  deletedBy     Int            @default(0)
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?      @db.Timestamp(0)
  createdAt     DateTime       @default(now()) @db.Timestamp(0)
  updatedAt     DateTime       @default(now()) @db.Timestamp(0)
  BinhLuan      BinhLuan[]
  CongViec      CongViec[]
  ThueCongViec  ThueCongViec[]
}

model ThueCongViec {
  id            Int        @id @default(autoincrement())
  ma_cong_viec  Int?
  ma_nguoi_thue Int?
  ngay_thue     DateTime?  @db.DateTime(0)
  hoan_thanh    Boolean?
  deletedBy     Int        @default(0)
  isDeleted     Boolean    @default(false)
  deletedAt     DateTime?  @db.Timestamp(0)
  createdAt     DateTime   @default(now()) @db.Timestamp(0)
  updatedAt     DateTime   @default(now()) @db.Timestamp(0)
  CongViec      CongViec?  @relation(fields: [ma_cong_viec], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Thue_CongViec")
  NguoiDung     NguoiDung? @relation(fields: [ma_nguoi_thue], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Thue_NguoiThue")

  @@index([ma_cong_viec], map: "FK_Thue_CongViec")
  @@index([ma_nguoi_thue], map: "FK_Thue_NguoiThue")
}
